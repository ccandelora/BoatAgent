<div class="max-w-3xl mx-auto space-y-6">
  <div class="flex items-center">
    <%= link_to boat_ai_recommendations_path(@boat), class: "text-blue-600 hover:text-blue-800 mr-3" do %>
      <svg class="h-5 w-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold text-gray-800 flex items-center">
      <svg class="h-6 w-6 text-purple-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
      </svg>
      <%= @recommendation.title %>
    </h1>
  </div>
  
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-purple-800 text-white p-4 flex justify-between items-center">
      <div class="flex items-center">
        <h2 class="font-semibold text-lg">AI Recommendation</h2>
        <% if @recommendation.task_type.present? %>
          <span class="ml-3 bg-purple-500 text-white text-xs px-2 py-1 rounded"><%= @recommendation.task_type.capitalize %></span>
        <% end %>
      </div>
      <div>
        <%= button_to convert_boat_ai_recommendation_path(@boat, @recommendation), method: :post, class: "bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-3 py-1 rounded" do %>
          Convert to Maintenance Task
        <% end %>
      </div>
    </div>
    
    <div class="p-6">
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-1">System Component</h3>
          <p class="text-gray-900"><%= @recommendation.system_component&.name || "Not specified" %></p>
        </div>
        
        <div>
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-1">Suggested Date</h3>
          <p class="text-gray-900"><%= @recommendation.suggested_date.strftime("%B %d, %Y") %></p>
        </div>
        
        <div class="md:col-span-2">
          <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-1">Description</h3>
          <div class="prose max-w-none text-gray-700">
            <%= simple_format(@recommendation.description) %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="bg-blue-800 text-white p-4">
      <h2 class="font-semibold text-lg">About This Recommendation</h2>
    </div>
    
    <div class="p-6">
      <p class="text-gray-600">
        This maintenance recommendation was generated by our AI based on your boat's specifications:
      </p>
      
      <div class="mt-4 grid md:grid-cols-3 gap-4">
        <div class="border border-gray-200 rounded-md p-3">
          <h3 class="text-sm font-medium text-gray-500">Boat</h3>
          <p class="text-gray-900 font-semibold"><%= @boat.name %></p>
        </div>
        
        <div class="border border-gray-200 rounded-md p-3">
          <h3 class="text-sm font-medium text-gray-500">Make/Model</h3>
          <p class="text-gray-900 font-semibold"><%= @boat.make %> <%= @boat.model %></p>
        </div>
        
        <div class="border border-gray-200 rounded-md p-3">
          <h3 class="text-sm font-medium text-gray-500">Year</h3>
          <p class="text-gray-900 font-semibold"><%= @boat.year %></p>
        </div>
        
        <% if @boat.engine_type.present? %>
          <div class="border border-gray-200 rounded-md p-3">
            <h3 class="text-sm font-medium text-gray-500">Engine</h3>
            <p class="text-gray-900 font-semibold"><%= @boat.engine_type %></p>
          </div>
        <% end %>
        
        <% if @boat.hours.present? %>
          <div class="border border-gray-200 rounded-md p-3">
            <h3 class="text-sm font-medium text-gray-500">Engine Hours</h3>
            <p class="text-gray-900 font-semibold"><%= @boat.hours %></p>
          </div>
        <% end %>
        
        <% if @boat.location.present? %>
          <div class="border border-gray-200 rounded-md p-3">
            <h3 class="text-sm font-medium text-gray-500">Location</h3>
            <p class="text-gray-900 font-semibold"><%= @boat.location %></p>
          </div>
        <% end %>
      </div>
      
      <p class="mt-6 text-sm text-gray-500">
        Recommendations are based on common maintenance practices for your type of vessel and may not account for all specific circumstances.
        Always consult your owner's manual or a certified marine technician for critical maintenance.
      </p>
    </div>
  </div>
</div>
