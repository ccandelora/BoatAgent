<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center">
      <%= link_to boat_path(@boat), class: "text-blue-600 hover:text-blue-800 mr-3" do %>
        <svg class="h-5 w-5 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
      <% end %>
      <h1 class="text-2xl font-bold text-gray-800">
        AI Recommendations for <%= @boat.name %>
      </h1>
    </div>
    <div>
      <%= link_to "Generate New Recommendations", boat_ai_recommendations_path(@boat, generate: true), class: "bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded" %>
    </div>
  </div>

  <% if flash[:recommendation_notice] %>
    <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded shadow-md mb-6 animate-fade-in">
      <div class="flex">
        <svg class="h-6 w-6 text-blue-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <%= flash[:recommendation_notice] %>
      </div>
    </div>
  <% end %>

  <% if @ai_recommendations.any? %>
    <div class="bg-white rounded-lg shadow-md">
      <div class="p-6 bg-purple-800 text-white">
        <div class="flex items-center">
          <svg class="h-6 w-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
          </svg>
          <h2 class="text-xl font-bold">AI-Generated Maintenance Recommendations</h2>
        </div>
        <p class="text-purple-200 mt-2">Based on your boat's make, model, year, and other factors, our AI suggests the following maintenance tasks:</p>
      </div>
      
      <div class="p-6">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @ai_recommendations.each do |recommendation| %>
            <div class="border border-purple-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-200">
              <div class="bg-purple-50 p-4">
                <div class="flex justify-between">
                  <h3 class="font-medium text-lg"><%= recommendation.title %></h3>
                  <% if recommendation.task_type.present? %>
                    <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded-full">
                      <%= recommendation.task_type.capitalize %>
                    </span>
                  <% end %>
                </div>
                <% if recommendation.system_component %>
                  <p class="text-xs text-gray-500 mt-1"><%= recommendation.system_component.name %></p>
                <% end %>
              </div>
              
              <div class="p-4">
                <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                  <%= recommendation.description %>
                </p>
                
                <div class="flex justify-between items-center">
                  <div>
                    <span class="text-xs text-gray-500">Suggested Date:</span>
                    <span class="text-sm text-gray-700"><%= recommendation.suggested_date.strftime("%b %d, %Y") %></span>
                  </div>
                  
                  <div class="flex space-x-2">
                    <%= link_to boat_ai_recommendation_path(@boat, recommendation), class: "text-purple-600 hover:text-purple-800 text-sm font-medium" do %>
                      View
                    <% end %>
                    
                    <%= button_to convert_boat_ai_recommendation_path(@boat, recommendation), method: :post, class: "bg-purple-600 hover:bg-purple-700 text-white text-xs px-3 py-1 rounded" do %>
                      Convert to Task
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="bg-white rounded-lg shadow-md p-12 text-center">
      <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="h-8 w-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-gray-800 mb-2">No Recommendations Yet</h3>
      <p class="text-gray-600 mb-6">Generate AI-powered maintenance recommendations for <%= @boat.name %>.</p>
      <%= link_to "Generate Recommendations", boat_ai_recommendations_path(@boat, generate: true), class: "bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-6 rounded-md" %>
    </div>
  <% end %>
</div>
