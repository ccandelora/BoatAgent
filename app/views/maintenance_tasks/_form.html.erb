<%= form_with(model: [boat, maintenance_task], class: "space-y-6", html: { multipart: true }) do |f| %>
  <% if maintenance_task.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 rounded-md p-4 mb-4">
      <h2 class="text-lg font-semibold"><%= pluralize(maintenance_task.errors.count, "error") %> prevented this task from being saved:</h2>
      <ul class="list-disc pl-5 mt-2">
        <% maintenance_task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="space-y-6">
      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500", required: true %>
      </div>

      <div>
        <%= f.label :system_component_id, "System Component", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :system_component_id, system_components, :id, :name, { include_blank: "-- Select Component --" }, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= f.label :due_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :due_date, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-xs text-gray-500 mt-1">When this task should be completed</p>
      </div>
    </div>

    <div class="space-y-6">
      <div>
        <%= f.label :cost, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <div class="relative rounded-md shadow-sm">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <span class="text-gray-500 sm:text-sm">$</span>
          </div>
          <%= f.number_field :cost, min: 0, step: 0.01, class: "w-full pl-7 rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>

      <div>
        <%= f.label :engine_hours, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :engine_hours, min: 0, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-xs text-gray-500 mt-1">Engine hours when this maintenance was/will be performed</p>
      </div>

      <div>
        <%= f.label :photo, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.file_field :photo, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500", accept: "image/*" %>
      </div>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :notes, rows: 3, placeholder: "Add any notes about this maintenance task...", class: "w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="pt-4 flex justify-end space-x-3">
    <% if maintenance_task.persisted? %>
      <%= link_to "Cancel", boat_maintenance_task_path(boat, maintenance_task), class: "border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 px-4 py-2 rounded-md text-sm font-medium" %>
    <% else %>
      <%= link_to "Cancel", boat_maintenance_tasks_path(boat), class: "border border-gray-300 bg-white text-gray-700 hover:bg-gray-100 px-4 py-2 rounded-md text-sm font-medium" %>
    <% end %>
    <%= f.submit maintenance_task.persisted? ? "Update Task" : "Create Task", class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md text-sm font-medium" %>
  </div>
<% end %> 