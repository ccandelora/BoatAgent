<div class="space-y-8">
  <div class="bg-white rounded-lg shadow-md p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Your Dashboard</h1>
      <div>
        <%= link_to "Add New Boat", new_boat_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded" %>
      </div>
    </div>
    
    <% if @boats.present? %>
      <div class="grid md:grid-cols-2 gap-6">
        <div>
          <h2 class="text-xl font-semibold mb-4 text-gray-700">Your Boats</h2>
          <div class="grid gap-4">
            <% @boats.each do |boat| %>
              <div class="border border-gray-200 rounded-md p-4 hover:bg-blue-50">
                <%= link_to boat_path(boat), class: "block" do %>
                  <h3 class="font-semibold text-lg"><%= boat.name %></h3>
                  <div class="text-sm text-gray-600">
                    <%= boat.year %> <%= boat.make %> <%= boat.model %>
                  </div>
                  <div class="text-sm text-gray-500 mt-2">
                    <% if boat.hours.present? %>
                      <span class="mr-3">Hours: <%= boat.hours %></span>
                    <% end %>
                    <% if boat.location.present? %>
                      <span>Location: <%= boat.location %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
        
        <div>
          <h2 class="text-xl font-semibold mb-4 text-gray-700">Quick Actions</h2>
          <div class="grid grid-cols-2 gap-4">
            <%= link_to new_boat_maintenance_task_path(@boats.first), class: "border border-gray-200 rounded-md p-4 flex flex-col items-center text-center hover:bg-blue-50" do %>
              <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mb-2">
                <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
              </div>
              <span class="font-medium">Log Maintenance</span>
            <% end %>
            
            <%= link_to user_prompts_path, class: "border border-gray-200 rounded-md p-4 flex flex-col items-center text-center hover:bg-blue-50" do %>
              <div class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center mb-2">
                <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
                </svg>
              </div>
              <span class="font-medium">Ask Boat AI</span>
            <% end %>
            
            <%= link_to boat_ai_recommendations_path(@boats.first), class: "border border-gray-200 rounded-md p-4 flex flex-col items-center text-center hover:bg-blue-50" do %>
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center mb-2">
                <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                </svg>
              </div>
              <span class="font-medium">View Recommendations</span>
            <% end %>
            
            <%= link_to system_components_path, class: "border border-gray-200 rounded-md p-4 flex flex-col items-center text-center hover:bg-blue-50" do %>
              <div class="w-10 h-10 bg-yellow-100 rounded-full flex items-center justify-center mb-2">
                <svg class="h-5 w-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <span class="font-medium">System Components</span>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-8">
        <h2 class="text-xl font-semibold mb-2">Welcome to Boat Maintenance Planner!</h2>
        <p class="text-gray-600 mb-6">Let's get started by adding your first boat.</p>
        <%= link_to "Add Your First Boat", new_boat_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded" %>
      </div>
    <% end %>
  </div>
  
  <% if @boats.present? && (@upcoming_tasks.present? || @overdue_tasks.present?) %>
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4 text-gray-700 flex items-center">
          <svg class="h-5 w-5 text-yellow-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Upcoming Tasks
        </h2>
        
        <% if @upcoming_tasks.present? %>
          <div class="divide-y">
            <% @upcoming_tasks.each do |task| %>
              <div class="py-3">
                <div class="flex justify-between">
                  <div>
                    <%= link_to task.title, boat_maintenance_task_path(task.boat, task), class: "font-medium text-blue-600 hover:text-blue-800" %>
                    <div class="text-sm text-gray-500"><%= task.boat.name %></div>
                  </div>
                  <div class="text-sm">
                    <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded">
                      <%= task.due_date.strftime("%b %d, %Y") %>
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 italic">No upcoming tasks scheduled.</p>
        <% end %>
      </div>
      
      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-xl font-semibold mb-4 text-gray-700 flex items-center">
          <svg class="h-5 w-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
          Overdue Tasks
        </h2>
        
        <% if @overdue_tasks.present? %>
          <div class="divide-y">
            <% @overdue_tasks.each do |task| %>
              <div class="py-3">
                <div class="flex justify-between">
                  <div>
                    <%= link_to task.title, boat_maintenance_task_path(task.boat, task), class: "font-medium text-blue-600 hover:text-blue-800" %>
                    <div class="text-sm text-gray-500"><%= task.boat.name %></div>
                  </div>
                  <div class="text-sm">
                    <span class="bg-red-100 text-red-800 px-2 py-1 rounded">
                      <%= time_ago_in_words(task.due_date) %> overdue
                    </span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 italic">No overdue tasks. Good job!</p>
        <% end %>
      </div>
    </div>
  <% end %>
  
  <% if @boats.present? && @recent_recommendations.present? %>
    <div class="bg-white rounded-lg shadow-md p-6">
      <h2 class="text-xl font-semibold mb-4 text-gray-700 flex items-center">
        <svg class="h-5 w-5 text-purple-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
        </svg>
        AI Recommendations
      </h2>
      
      <div class="grid md:grid-cols-3 gap-4">
        <% @recent_recommendations.each do |rec| %>
          <div class="border border-gray-200 rounded-md p-4 hover:bg-purple-50">
            <%= link_to boat_ai_recommendation_path(rec.boat, rec) do %>
              <h3 class="font-medium"><%= rec.title %></h3>
              <div class="text-sm text-gray-500 mt-1">
                <div><%= rec.boat.name %></div>
                <div>Suggested: <%= rec.suggested_date.strftime("%b %d, %Y") %></div>
                <% if rec.task_type.present? %>
                  <span class="mt-2 inline-block bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded">
                    <%= rec.task_type.capitalize %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div> 