<div class="max-w-4xl mx-auto">
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="p-6 bg-blue-800 text-white">
      <h1 class="text-2xl font-bold">Ask the Boat AI</h1>
      <p class="text-blue-200 mt-1">Get answers to your boat maintenance questions</p>
    </div>
    
    <div class="p-6">
      <%= form_with(model: @user_prompt, url: user_prompts_path, class: "mb-8") do |f| %>
        <div class="flex flex-col space-y-2">
          <%= f.label :content, "Your Question", class: "text-sm font-medium text-gray-700" %>
          <%= f.text_area :content, rows: 3, class: "rounded-md border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500", placeholder: "E.g., How often should I change the impeller on my outboard motor?", required: true %>
        </div>
        
        <div class="mt-3 flex justify-end">
          <%= f.submit "Ask AI", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded" %>
        </div>
      <% end %>
      
      <% if @user_prompts.any? %>
        <h2 class="text-xl font-semibold text-gray-800 mb-4">Conversation History</h2>
        
        <div class="space-y-6">
          <% @user_prompts.each do |prompt| %>
            <div class="rounded-lg border border-gray-200 overflow-hidden">
              <div class="bg-gray-50 p-4">
                <div class="flex items-start">
                  <div class="flex-shrink-0 mr-3">
                    <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                      <svg class="h-4 w-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                    </div>
                  </div>
                  <div>
                    <p class="font-medium">Your Question</p>
                    <p class="text-gray-700 mt-1"><%= prompt.content %></p>
                    <p class="text-xs text-gray-500 mt-1"><%= prompt.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
                  </div>
                </div>
              </div>
              
              <div class="p-4">
                <div class="flex items-start">
                  <div class="flex-shrink-0 mr-3">
                    <div class="w-8 h-8 bg-purple-100 rounded-full flex items-center justify-center">
                      <svg class="h-4 w-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                      </svg>
                    </div>
                  </div>
                  <div>
                    <p class="font-medium">Boat AI</p>
                    <div class="text-gray-700 mt-1 prose">
                      <%= simple_format(prompt.response) %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="h-8 w-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-800">No Questions Yet</h3>
          <p class="text-gray-600 mt-1">Ask your first question to get started!</p>
        </div>
      <% end %>
    </div>
  </div>
  
  <div class="mt-8 bg-white rounded-lg shadow-md p-6">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Example Questions</h2>
    
    <div class="grid md:grid-cols-2 gap-4">
      <div class="border border-gray-200 rounded-md p-4 hover:bg-blue-50 cursor-pointer" onclick="document.getElementById('user_prompt_content').value = this.querySelector('p').textContent; document.getElementById('user_prompt_content').focus();">
        <h3 class="font-medium text-blue-600">Seasonal Maintenance</h3>
        <p class="text-gray-600 mt-1">What should I check before launching my boat this spring?</p>
      </div>
      
      <div class="border border-gray-200 rounded-md p-4 hover:bg-blue-50 cursor-pointer" onclick="document.getElementById('user_prompt_content').value = this.querySelector('p').textContent; document.getElementById('user_prompt_content').focus();">
        <h3 class="font-medium text-blue-600">Engine Care</h3>
        <p class="text-gray-600 mt-1">How often should I change the oil in my Yamaha 150HP outboard?</p>
      </div>
      
      <div class="border border-gray-200 rounded-md p-4 hover:bg-blue-50 cursor-pointer" onclick="document.getElementById('user_prompt_content').value = this.querySelector('p').textContent; document.getElementById('user_prompt_content').focus();">
        <h3 class="font-medium text-blue-600">Troubleshooting</h3>
        <p class="text-gray-600 mt-1">Why is my bilge pump running constantly?</p>
      </div>
      
      <div class="border border-gray-200 rounded-md p-4 hover:bg-blue-50 cursor-pointer" onclick="document.getElementById('user_prompt_content').value = this.querySelector('p').textContent; document.getElementById('user_prompt_content').focus();">
        <h3 class="font-medium text-blue-600">Winterization</h3>
        <p class="text-gray-600 mt-1">What's the best way to winterize my boat in New England?</p>
      </div>
    </div>
  </div>
</div>
